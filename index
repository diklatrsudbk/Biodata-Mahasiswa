<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Form Biodata Mahasiswa</title>
    <style>
        body { font-family: sans-serif; padding: 20px; }
        .container { max-width: 400px; margin: auto; }
        input, textarea { width: 100%; padding: 8px; margin: 8px 0; border: 1px solid #ccc; }
        button { background: #28a745; color: white; border: none; padding: 10px; width: 100%; cursor: pointer; }
    </style>
</head>
<body>

<div class="container">
    <h2>Form Biodata Mahasiswa</h2>
    <form id="formBiodata">
        <label>Nama Lengkap</label>
        <input type="text" name="nama" required>

        <label>Nama Institusi</label>
        <input type="text" name="institusi" required>

        <label>Nama Jurusan</label>
        <input type="text" name="jurusan" required>

        <label>NIM</label>
        <input type="text" name="nim" required>

        <label>Alamat</label>
        <textarea name="alamat" required></textarea>

        <label>No. HP</label>
        <input type="tel" name="nohp" required>

        <button type="submit" id="btnKirim">Kirim Data</button>
    </form>
</div>

<script>
    const scriptURL = 'https://script.google.com/macros/s/AKfycbzHAqRmQtXcT5TUfOJNg9GbVFgRMXFbzCImUgamI8tdwfqkBxI4w9xadem9ngcghBGO/exec'; // Ganti dengan URL dari Langkah 2
    const form = document.getElementById('formBiodata');
    const btnKirim = document.getElementById('btnKirim');

    form.addEventListener('submit', e => {
        e.preventDefault();
        btnKirim.disabled = true;
        btnKirim.innerHTML = "Sedang Mengirim...";

        fetch(scriptURL, { method: 'POST', body: new FormData(form)})
            .then(response => {
                alert("Data berhasil tersimpan!");
                btnKirim.disabled = false;
                btnKirim.innerHTML = "Kirim Data";
                form.reset();
            })
            .catch(error => {
                console.error('Error!', error.message);
                alert("Terjadi kesalahan, coba lagi.");
                btnKirim.disabled = false;
            });
    });
</script>

</body>
</html>
